<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main fragment container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── RTK Status HUD (always visible) ───────────────────── -->
    <LinearLayout
        android:id="@+id/hud_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="#CC000000"
        app:layout_anchor="@id/fragment_container"
        app:layout_anchorGravity="top">

        <!-- RTK Fix type chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/rtk_status_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NONE"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            app:chipBackgroundColor="#FF9E9E9E" />

        <!-- Accuracy display -->
        <TextView
            android:id="@+id/accuracy_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:layout_marginStart="8dp" />

        <!-- Satellite count -->
        <TextView
            android:id="@+id/sat_count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0 sats"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:layout_marginStart="8dp" />

        <!-- Dual frequency badge -->
        <TextView
            android:id="@+id/dual_freq_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="L1+L5"
            android:textColor="#FF4CAF50"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- NTRIP status -->
        <View
            android:id="@+id/ntrip_status_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dot_red"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/ntrip_mount_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TUSAGA"
            android:textColor="#AAFFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?android:attr/windowBackground"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

    <!-- FAB: Toggle Map/AR -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:src="@drawable/ic_ar"
        app:tint="#FFFFFF" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
